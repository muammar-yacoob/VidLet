<html>
<head>
<meta http-equiv="X-UA-Compatible" content="IE=edge">
<title>VidLet</title>
<hta:application
  id="VidLetOptimize"
  applicationName="VidLetOptimize"
  icon="tv.ico"
  border="thin"
  borderStyle="normal"
  caption="no"
  innerBorder="no"
  maximizeButton="no"
  minimizeButton="no"
  showInTaskbar="no"
  singleInstance="yes"
  scroll="no"
  contextMenu="no"
  selection="no"
  sysmenu="no"
/>
<style>
  *{margin:0;padding:0;cursor:default;box-sizing:border-box}
  html,body{width:100%;height:100%;overflow:hidden}
  body{background:#18181b;font-family:Segoe UI,sans-serif;color:#e4e4e7;padding:16px 20px;border:1px solid #444;opacity:1;transition:opacity .3s}
  body.fade-out{opacity:0}
  .row{display:flex;align-items:center;gap:10px}
  .icon{width:24px;height:24px}
  .title{font-size:13px;font-weight:600;color:#a855f7}
  .status{font-size:11px;color:#a1a1aa;margin-top:8px;white-space:nowrap;overflow:hidden;text-overflow:ellipsis}
  .result{font-size:11px;color:#22c55e;margin-top:8px;display:none}
  .bar{width:100%;height:3px;background:#27272a;border-radius:2px;margin-top:10px;overflow:hidden}
  .fill{height:100%;background:linear-gradient(90deg,#a855f7,#c084fc);width:5%;transition:width .2s}
</style>
<script language="javascript">
  var w = 320, h = 150;
  window.resizeTo(w, h);
  var left = Math.round((screen.availWidth - w) / 2);
  var top = Math.round((screen.availHeight - h) / 2);
  window.moveTo(left, top);

  var fso = new ActiveXObject("Scripting.FileSystemObject");
  var wshShell = new ActiveXObject("WScript.Shell");
  var tempDir = wshShell.ExpandEnvironmentStrings("%TEMP%");
  var doneFile = tempDir + "\\vidlet-optimize-done.tmp";
  var progressFile = tempDir + "\\vidlet-optimize-progress.tmp";
  var animPct = 5;
  var isClosing = false;

  function fadeAndClose() {
    if (isClosing) return;
    isClosing = true;
    document.body.className = "fade-out";
    setTimeout(function() { window.close(); }, 300);
  }

  setTimeout(function() { if (!isClosing) window.close(); }, 120000);

  var poll = setInterval(function() {
    if (fso.FileExists(progressFile)) {
      try {
        var pf = fso.OpenTextFile(progressFile, 1);
        var pdata = pf.ReadAll();
        pf.Close();
        var parts = pdata.split("|");
        var nums = parts[0].split("/");
        var current = parseInt(nums[0], 10);
        var total = parseInt(nums[1], 10);
        var fname = parts.length > 1 ? parts[1] : "";
        if (total > 0) {
          var pct = Math.round(((current - 1) / total) * 90) + 5;
          document.getElementById("fill").style.width = pct + "%";
          animPct = pct;
          document.getElementById("status").innerText = total > 1
            ? current + "/" + total + "  " + fname : fname;
        }
      } catch(e) {}
    } else if (animPct < 90) {
      animPct += 1;
      document.getElementById("fill").style.width = animPct + "%";
    }

    if (fso.FileExists(doneFile)) {
      clearInterval(poll);
      var msg = "Done";
      try {
        var f = fso.OpenTextFile(doneFile, 1);
        msg = f.ReadAll();
        f.Close();
        fso.DeleteFile(doneFile);
      } catch(e) {}
      try { fso.DeleteFile(progressFile); } catch(e) {}
      document.getElementById("fill").style.width = "100%";
      document.getElementById("status").style.display = "none";
      var res = document.getElementById("result");
      res.innerText = msg;
      res.style.display = "block";
      setTimeout(fadeAndClose, 3000);
    }
  }, 200);
</script>
</head>
<body>
  <div class="row">
    <img class="icon" src="tv.png">
    <div class="title">Optimizing Lottie</div>
  </div>
  <div class="status" id="status">Processing...</div>
  <div class="result" id="result"></div>
  <div class="bar"><div class="fill" id="fill"></div></div>
</body>
</html>
