{
  "name": "@spark-apps/vidlet",
  "version": "1.2.0",
  "description": "Free local auto-captions, video compression, voice cleanup, GIF conversion & more - right-click context menu for Windows (WSL)",
  "type": "module",
  "bin": {
    "vidlet": "./dist/cli.js",
    "vidlet-mcp": "./mcp.js"
  },
  "files": [
    "dist",
    "icons",
    "mcp.js",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "dev": "tsup --watch",
    "postinstall": "node dist/cli.js install",
    "preuninstall": "node dist/cli.js uninstall",
    "lint": "biome lint src",
    "lint:fix": "biome lint --write src",
    "format": "biome format --write src",
    "check": "biome check --write src",
    "test": "vitest",
    "test:run": "vitest run",
    "typecheck": "tsc --noEmit",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "video",
    "ffmpeg",
    "auto-captions",
    "subtitles",
    "whisper",
    "transcribe",
    "compress",
    "gif",
    "capcut-alternative",
    "voice-cleanup",
    "denoise",
    "tts",
    "voiceover",
    "voice-cloning",
    "wsl",
    "windows",
    "context-menu",
    "video-editor"
  ],
  "author": "spark-apps",
  "license": "MIT",
  "homepage": "https://vidlet.app",
  "repository": {
    "type": "git",
    "url": "https://github.com/muammar-yacoob/VidLet.git"
  },
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@dotlottie/dotlottie-js": "^1.6.3",
    "@modelcontextprotocol/sdk": "^1.29.0",
    "commander": "^13.1.0",
    "execa": "^9.5.2",
    "express": "^5.2.1",
    "figlet": "^1.9.4",
    "gifsicle": "^7.0.1",
    "lottie-web": "^5.13.0",
    "msedge-tts": "^2.0.7",
    "pixelmatch": "^6.0.0",
    "pngjs": "^7.0.0",
    "prompts": "^2.4.2",
    "zod": "^3.24.2"
  },
  "devDependencies": {
    "@biomejs/biome": "^1.9.4",
    "@types/express": "^5.0.6",
    "@types/figlet": "^1.7.0",
    "@types/node": "^22.10.7",
    "@types/pixelmatch": "^5.2.6",
    "@types/pngjs": "^6.0.5",
    "@types/prompts": "^2.4.9",
    "tsup": "^8.3.5",
    "typescript": "^5.7.3",
    "vitest": "^3.0.4"
  }
}
